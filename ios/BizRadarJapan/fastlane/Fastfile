default_platform(:ios)

platform :ios do
  desc "Build and upload BizRadar Japan to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
      duration: 1200,
      in_house: false
    )

    build_app(
      project: "BizRadarJapan.xcodeproj",
      scheme: "BizRadarJapan",
      export_method: "app-store",
      clean: true,
      xcargs: [
        "-allowProvisioningUpdates",
        "DEVELOPMENT_TEAM=#{ENV.fetch("APPLE_TEAM_ID")}",
        "PRODUCT_BUNDLE_IDENTIFIER=#{ENV.fetch("BUNDLE_ID")}"
      ].join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
